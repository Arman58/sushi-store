{
  "name": "sushi-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\" --write",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' prisma/seed.ts"
  },
  "prisma": {
    "seed": "npm run prisma:seed"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/material-nextjs": "^7.3.6",
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.90.12",
    "cloudinary": "^2.10.0",
    "framer-motion": "^12.38.0",
    "js-cookie": "^3.0.5",
    "next": "16.2.3",
    "notistack": "^3.0.2",
    "prisma": "^6.19.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.68.0",
    "swiper": "^12.1.3",
    "zod": "^3.25.28",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
