# --- INSTRUCTIONS ---
# For PRODUCTION (Vercel): Use real DB, Prod Telegram bot, Prod Upstash.
# For PREVIEW/DEV: Use Neon dev branch DB, Test Telegram bot, RESEND_DEV_REDIRECT_TO=your_email@gmail.com
# NEXT_PUBLIC_SITE_URL is optional for Preview (Vercel uses VERCEL_URL automatically).

# PostgreSQL (Neon / Supabase / Vercel Postgres)
DATABASE_URL=

# NextAuth (client accounts: login / register)
NEXTAUTH_SECRET=
# Production: https://www.eastwestnh.com (канонический домен, push и PWA)
NEXTAUTH_URL=

# Public site URL (canonical links, emails, OG)
# Production: https://www.eastwestnh.com
NEXT_PUBLIC_SITE_URL=

# Admin panel (Basic Auth + session cookie)
ADMIN_USER=
ADMIN_PASS=
ADMIN_SESSION_SECRET=

# Resend (order emails, OTP verification, welcome emails)
RESEND_API_KEY=
# Production example: East West Delivery <noreply@eastwestnh.com>
RESEND_FROM=
# Optional: redirect all outgoing mail in local dev and Vercel Preview
RESEND_DEV_REDIRECT_TO=

# Telegram (kitchen notifications + webhook)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_TOKEN=

# Cloudinary (admin product image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional hero background (Cloudinary URL preferred)
NEXT_PUBLIC_HERO_IMAGE_URL=

# Contact info shown on storefront
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=

# Upstash Redis (rate limiting, OTP storage)
# REQUIRED in production - without these vars rate limits fail closed (429) and OTP codes are not shared across serverless instances
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (PWA order status notifications)
# Generate with: npm run generate:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Sentry (error monitoring + performance tracing)
# Without NEXT_PUBLIC_SENTRY_DSN the SDK stays disabled and builds still succeed.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Source map upload (CI / Vercel build only)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
