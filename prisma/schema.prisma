datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Category {
  id           Int                   @id @default(autoincrement())
  slug         String                @unique
  position     Int                   @default(0)
  isActive     Boolean               @default(true)
  image        String?
  products     Product[]
  createdAt    DateTime              @default(now())
  translations CategoryTranslation[]
}

model Product {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  /// Цена в целых AMD (драмах), без минорных единиц. Пример: 3500 = 3500 ֏.
  price          Int
  weight         Int?
  images         Json            @default("[]")
  mainImage      String?
  isActive       Boolean         @default(true)
  isAvailable    Boolean         @default(true)
  minQty         Int             @default(1)
  maxQty         Int?
  upsells        ProductUpsell[] @relation("UpsellSource")
  upsellOf       ProductUpsell[] @relation("UpsellSuggested")
  category       Category?       @relation(fields: [categoryId], references: [id])
  categoryId     Int?
  createdAt      DateTime        @default(now())
  modifierGroups ModifierGroup[]

  ratingAvg      Float           @default(0)
  ratingCount    Int             @default(0)
  reviews        Review[]
  translations   ProductTranslation[]
  cartLines      CartLine[]
}

/** Отзыв покупателя. Один отзыв на товар от пользователя (upsert-семантика в API). */
model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** 1..5 - валидируется в API. */
  rating    Int
  /** Текст отзыва; может быть пустым (оценка без текста). */
  text      String   @default("")
  /** true - у автора есть доставленный заказ с этим товаром на момент создания. */
  verifiedPurchase Boolean @default(false)
  /** Денормализованный счётчик голосов «Полезно». */
  helpfulCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes ReviewVote[]

  @@unique([productId, userId])
  @@index([productId, createdAt])
  @@index([productId, rating])
}

/** Голос «Полезно» - один на отзыв от пользователя. */
model ReviewVote {
  id       Int    @id @default(autoincrement())
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([userId])
}

/** Промо-баннер на главной (карусель под hero). Управляется из админки. */
model Banner {
  id           Int                 @id @default(autoincrement())
  image        String
  href         String?
  position     Int                 @default(0)
  isActive     Boolean             @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime            @default(now())
  translations BannerTranslation[]
}

/** Кросс-селл «с этим берут»: к товару productId предлагается suggested. */
model ProductUpsell {
  id          Int     @id @default(autoincrement())
  productId   Int
  product     Product @relation("UpsellSource", fields: [productId], references: [id], onDelete: Cascade)
  suggestedId Int
  suggested   Product @relation("UpsellSuggested", fields: [suggestedId], references: [id], onDelete: Cascade)
  /** Порядок показа (меньше - выше). */
  position    Int     @default(0)

  @@unique([productId, suggestedId])
  @@index([productId])
}

/** Группа опций к товару (размер, добавки). maxChoices: 0 = без верхней границы. */
model ModifierGroup {
  id           Int                        @id @default(autoincrement())
  productId    Int
  product      Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  required     Boolean                    @default(false)
  maxChoices   Int                        @default(1)
  position     Int                        @default(0)
  modifiers    Modifier[]
  translations ModifierGroupTranslation[]

  @@index([productId])
}

model Modifier {
  id              Int                   @id @default(autoincrement())
  priceDelta      Int                   @default(0)
  modifierGroupId Int
  modifierGroup   ModifierGroup         @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  position        Int                   @default(0)
  translations    ModifierTranslation[]

  @@index([modifierGroupId])
}


enum PaymentMethod {
  CASH
  CARD
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  NEW        // Заказ принят
  COOKING    // Готовится
  DELIVERING // В пути
  DONE       // Доставлен
  CANCELLED  // Отменён
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id              Int           @id @default(autoincrement())
  code            String        @unique
  discountType    DiscountType
  discountValue   Int
  minOrderAmount  Int?
  maxUsages       Int?
  timesUsed       Int           @default(0)
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  conditions      Json?         /// Условия применения промокода (JSON-массив правил)
  actions         Json?         /// Действия промокода (бесплатная доставка, скидка на категорию и т.д.)
  orders          Order[]
}


model DeliveryZone {
  id                      Int                       @id @default(autoincrement())
  position                Int                       @default(0)
  deliveryPrice           Int
  minOrderAmount          Int
  requiresManagerApproval Boolean                   @default(false)
  isActive                Boolean                   @default(true)
  orders                  Order[]
  translations            DeliveryZoneTranslation[]
}

model Order {
  id               Int           @id @default(autoincrement())
  /** Уникальный ключ для гостевого доступа к странице трекинга: /order/[id]?key=… */
  accessToken      String        @unique @default(uuid())
  createdAt        DateTime      @default(now())
  name             String
  phone            String
  address          String?
  comment          String?
  payment          PaymentMethod
  delivery         DeliveryType
  status           OrderStatus   @default(NEW)
  /** Ожидаемое время готовности/доставки - задаёт кухня (Telegram / админка). */
  estimatedDeliveryAt DateTime?
  /** Сумма позиций (без доставки), на момент оформления */
  subtotalBeforeDiscount Int @default(0)
  /** Скидка по промокоду (минорные единицы); 0 если промокода не было */
  discountAmount   Int           @default(0)
  totalPrice       Int
  deliveryZoneId   Int?
  deliveryZone     DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  /** Название зоны на момент заказа */
  deliveryZoneName String?
  /** Стоимость доставки (минорные единицы); 0 для самовывоза */
  deliveryPrice    Int           @default(0)

  promoCodeId Int?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  /** Покупатель (NextAuth). null для гостей и старых заказов до миграции. */
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /** Язык витрины на момент оформления (push, письма). */
  locale String @default("hy")

  /** Наличные: сумма, с которой готовить сдачу (֏). null - сдача не нужна. */
  changeFrom Int?

  /** Предзаказ «ко времени»: желаемое время доставки/самовывоза. null - как можно скорее. */
  scheduledFor DateTime?

  items      OrderItem[]

  @@index([userId])
  /** Кухня/админка: выборки по статусу с сортировкой по времени. */
  @@index([status, createdAt])
  /** Админ-список и аналитика: сортировка/фильтр по дате. */
  @@index([createdAt])
  @@index([phone])
}

/**
 * Покупатель сайта. Email + пароль (NextAuth Credentials, JWT).
 * Lazy Verification: emailVerified null не блокирует заказы.
 * Телефон указывается на чекауте.
 */
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  phone         String?   @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  orders        Order[]
  subscriptions PushSubscription[]
  savedAddresses SavedAddress[]
  reviews       Review[]
  reviewVotes   ReviewVote[]
  cart          Cart?
}

model Cart {
  id               Int        @id @default(autoincrement())
  userId           Int        @unique
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  appliedPromoCode String?
  lines            CartLine[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

/**
 * Нормализованная позиция серверной корзины (H-3).
 * selectedModifiers остаётся JSON snapshot — состав модификаторов меняется редко
 * и не нужен для аналитики «сколько productId в корзинах».
 */
model CartLine {
  id                  Int      @id @default(autoincrement())
  cartId              Int
  cart                Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  /** Клиентский ключ строки: productId + набор модификаторов */
  cartItemId          String
  productId           Int
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                String
  basePrice           Int
  quantity            Int
  selectedModifiers   Json     @default("[]")
  calculatedItemPrice Int
  image               String?
  position            Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([cartId, cartItemId])
  @@index([productId])
  @@index([cartId])
}

model SavedAddress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  street    String
  apartment String?
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    Int?
  createdAt DateTime @default(now())

  @@index([userId])
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  order     Order @relation(fields: [orderId], references: [id])
  orderId   Int

  // просто храним id продукта, без relation и без модели Product
  productId Int?

  name      String
  price     Int
  quantity  Int
  /** Снимок выбранных модификаторов на момент заказа: [{ id, name, priceDelta }] */
  selectedModifiers Json @default("[]")
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     String   @db.VarChar(2) // hy, ru, en
  name       String

  @@unique([categoryId, locale])
}

model ProductTranslation {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      String   @db.VarChar(2)
  name        String
  description String?
  composition String?

  @@unique([productId, locale])
}

model BannerTranslation {
  id       Int    @id @default(autoincrement())
  bannerId Int
  banner   Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  locale   String @db.VarChar(2)
  title    String
  ctaText  String?

  @@unique([bannerId, locale])
}

model ModifierGroupTranslation {
  id              Int           @id @default(autoincrement())
  modifierGroupId Int
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  locale          String        @db.VarChar(2)
  name            String

  @@unique([modifierGroupId, locale])
}

model ModifierTranslation {
  id         Int      @id @default(autoincrement())
  modifierId Int
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  locale     String   @db.VarChar(2)
  name       String

  @@unique([modifierId, locale])
}

model DeliveryZoneTranslation {
  id             Int          @id @default(autoincrement())
  deliveryZoneId Int
  deliveryZone   DeliveryZone @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)
  locale         String       @db.VarChar(2)
  name           String
  description    String?

  @@unique([deliveryZoneId, locale])
}
