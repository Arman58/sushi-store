datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Category {
  id        Int       @id @default(autoincrement())
  name      Json      @db.JsonB
  slug      String    @unique
  /** Порядок на витрине (меньше - выше). */
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  /** Фото категории на витрине (Cloudinary URL). null - берётся обложка первого товара. */
  image     String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id             Int             @id @default(autoincrement())
  name           Json            @db.JsonB
  slug           String          @unique
  description    Json?           @db.JsonB
  composition    Json?           @db.JsonB
  price          Int
  weight         Int?
  images         Json            @default("[]")
  /** Обложка на витрине; должна совпадать с одним из URL в `images`, иначе игнорируется при сохранении. */
  mainImage      String?
  /** На витрине: если false - гость не видит товар в меню/на главной; при заказе из сохранённой корзины - понятная ошибка. */
  isActive       Boolean         @default(true)
  /** Стоп-лист: false - «закончилось сегодня», товар виден, но заказ заблокирован. */
  isAvailable    Boolean         @default(true)
  /** Минимальное количество в заказе (первое добавление кладёт столько). */
  minQty         Int             @default(1)
  /** Максимум на заказ; null - без лимита. */
  maxQty         Int?
  /** Кросс-селл: что предложить к этому товару (задаётся в админке). */
  upsells        ProductUpsell[] @relation("UpsellSource")
  /** Обратная связь: в каких товарах этот предлагается. */
  upsellOf       ProductUpsell[] @relation("UpsellSuggested")
  category       Category?       @relation(fields: [categoryId], references: [id])
  categoryId     Int?
  createdAt      DateTime        @default(now())
  modifierGroups ModifierGroup[]

  /** Денормализованные агрегаты отзывов; пересчитываются в транзакции при изменении отзывов. */
  ratingAvg   Float    @default(0)
  ratingCount Int      @default(0)
  reviews     Review[]
}

/** Отзыв покупателя. Один отзыв на товар от пользователя (upsert-семантика в API). */
model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** 1..5 - валидируется в API. */
  rating    Int
  /** Текст отзыва; может быть пустым (оценка без текста). */
  text      String   @default("")
  /** true - у автора есть доставленный заказ с этим товаром на момент создания. */
  verifiedPurchase Boolean @default(false)
  /** Денормализованный счётчик голосов «Полезно». */
  helpfulCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes ReviewVote[]

  @@unique([productId, userId])
  @@index([productId, createdAt])
  @@index([productId, rating])
}

/** Голос «Полезно» - один на отзыв от пользователя. */
model ReviewVote {
  id       Int    @id @default(autoincrement())
  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([userId])
}

/** Промо-баннер на главной (карусель под hero). Управляется из админки. */
model Banner {
  id        Int       @id @default(autoincrement())
  /** Cloudinary URL (рекомендация: 1200x480). */
  image     String
  /** Подпись для доступности и заголовка поверх фото; локализованная. */
  title     Json      @default("{}") @db.JsonB
  /** Текст CTA-кнопки; пусто - дефолтный «Смотреть». Локализованный. */
  ctaText   Json      @default("{}") @db.JsonB
  /** Куда ведёт клик: внутренний путь (/menu?category=...) или https-ссылка. null - некликабельный. */
  href      String?
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  /** Показ с/по; null - без ограничения. */
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

/** Кросс-селл «с этим берут»: к товару productId предлагается suggested. */
model ProductUpsell {
  id          Int     @id @default(autoincrement())
  productId   Int
  product     Product @relation("UpsellSource", fields: [productId], references: [id], onDelete: Cascade)
  suggestedId Int
  suggested   Product @relation("UpsellSuggested", fields: [suggestedId], references: [id], onDelete: Cascade)
  /** Порядок показа (меньше - выше). */
  position    Int     @default(0)

  @@unique([productId, suggestedId])
  @@index([productId])
}

/** Группа опций к товару (размер, добавки). maxChoices: 0 = без верхней границы. */
model ModifierGroup {
  id         Int        @id @default(autoincrement())
  name       Json       @db.JsonB
  productId  Int
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  required   Boolean    @default(false)
  maxChoices Int        @default(1)
  /** Порядок вывода группы в UI (по возрастанию). */
  position   Int        @default(0)
  modifiers  Modifier[]

  @@index([productId])
}

model Modifier {
  id              Int           @id @default(autoincrement())
  name            Json          @db.JsonB
  /** Дельта к цене товара. Может быть 0 или отрицательной (скидка за «без сыра» и т.п.). */
  priceDelta      Int           @default(0)
  modifierGroupId Int
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  /** Порядок вывода опции внутри группы (по возрастанию). */
  position        Int           @default(0)

  @@index([modifierGroupId])
}


enum PaymentMethod {
  CASH
  CARD
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  NEW        // Заказ принят
  COOKING    // Готовится
  DELIVERING // В пути
  DONE       // Доставлен
  CANCELLED  // Отменён
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id              Int           @id @default(autoincrement())
  code            String        @unique
  discountType    DiscountType
  discountValue   Int
  minOrderAmount  Int?
  maxUsages       Int?
  timesUsed       Int           @default(0)
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  orders          Order[]
}


model DeliveryZone {
  id             Int      @id @default(autoincrement())
  /** Порядок в админке и на витрине (меньше - выше) */
  position       Int      @default(0)
  name           Json     @db.JsonB
  deliveryPrice  Int
  minOrderAmount Int
  /** Пояснение на чекауте (напр. плавающая цена доставки) */
  description    Json?    @default("{}") @db.JsonB
  /** true - оформление как заявка, менеджер перезванивает для уточнения */
  requiresManagerApproval Boolean @default(false)
  isActive       Boolean  @default(true)
  orders         Order[]
}

model Order {
  id               Int           @id @default(autoincrement())
  /** Уникальный ключ для гостевого доступа к странице трекинга: /order/[id]?key=… */
  accessToken      String        @unique @default(uuid())
  createdAt        DateTime      @default(now())
  name             String
  phone            String
  address          String?
  comment          String?
  payment          PaymentMethod
  delivery         DeliveryType
  status           OrderStatus   @default(NEW)
  /** Ожидаемое время готовности/доставки - задаёт кухня (Telegram / админка). */
  estimatedDeliveryAt DateTime?
  /** Сумма позиций (без доставки), на момент оформления */
  subtotalBeforeDiscount Int @default(0)
  /** Скидка по промокоду (минорные единицы); 0 если промокода не было */
  discountAmount   Int           @default(0)
  totalPrice       Int
  deliveryZoneId   Int?
  deliveryZone     DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  /** Название зоны на момент заказа */
  deliveryZoneName String?
  /** Стоимость доставки (минорные единицы); 0 для самовывоза */
  deliveryPrice    Int           @default(0)

  promoCodeId Int?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  /** Покупатель (NextAuth). null для гостей и старых заказов до миграции. */
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  items      OrderItem[]

  @@index([userId])
}

/**
 * Покупатель сайта. Email + пароль (NextAuth Credentials, JWT).
 * Lazy Verification: emailVerified null не блокирует заказы.
 * Телефон указывается на чекауте.
 */
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  phone         String?   @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  orders        Order[]
  subscriptions PushSubscription[]
  savedAddresses SavedAddress[]
  reviews       Review[]
  reviewVotes   ReviewVote[]
}

model SavedAddress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  street    String
  apartment String?
  comment   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    Int?
  createdAt DateTime @default(now())

  @@index([userId])
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  order     Order @relation(fields: [orderId], references: [id])
  orderId   Int

  // просто храним id продукта, без relation и без модели Product
  productId Int?

  name      String
  price     Int
  quantity  Int
  /** Снимок выбранных модификаторов на момент заказа: [{ id, name, priceDelta }] */
  selectedModifiers Json @default("[]")
}
