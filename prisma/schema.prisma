datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  products  Product[]
  createdAt DateTime @default(now())
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  composition String?
  price       Int
  weight      Int?
  images      Json      @default("[]")
  /** Обложка на витрине; должна совпадать с одним из URL в `images`, иначе игнорируется при сохранении. */
  mainImage   String?
  isActive    Boolean   @default(true)
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  Int?
  createdAt   DateTime  @default(now())
}


enum PaymentMethod {
  CASH
  CARD
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  NEW
  PREPARING
  DELIVERING
  DONE
  CANCELLED
}

model Order {
  id         Int           @id @default(autoincrement())
  createdAt  DateTime      @default(now())
  name       String
  phone      String
  address    String?
  comment    String?
  payment    PaymentMethod
  delivery   DeliveryType
  status     OrderStatus   @default(NEW)
  totalPrice Int

  items      OrderItem[]
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  order     Order @relation(fields: [orderId], references: [id])
  orderId   Int

  // просто храним id продукта, без relation и без модели Product
  productId Int?

  name      String
  price     Int
  quantity  Int
}

